{
  "expo": {
    "name": "VaxSync",
    "slug": "vaxsyncApp",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "extra": {
      "eas": {
        "projectId": "283dab38-62ae-40ce-98a1-180c9a484844"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.vaxsync.app"
    },
    "android": {
      "package": "com.vaxsync.app",
      "versionCode": 1,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/adaptive-icon.png",
        "backgroundColor": "#1e40af"
      },
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "NOTIFICATIONS",
        "RECEIVE_BOOT_COMPLETED",
        "SCHEDULE_EXACT_ALARM",
        "USE_EXACT_ALARM",
        "VIBRATE",
        "INTERNET",
        "ACCESS_NETWORK_STATE"
      ],
      "config": {
        "googleMaps": {
          "apiKey": "AIzaSyDhfgoyumPBmt0HVYBc8QzFZ6LJDAGI1Uc"
        }
      },
      "edgeToEdgeEnabled": true
    },
    "web": {
      "bundler": "metro",
      "output": "static",
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#1e40af",
          "androidMode": "default",
          "androidCollapsedTitle": "VaxSync"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow VaxSync to use your location to find nearby vaccination centers."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
